# Environment Variables Configuration
# Copy this file to .env and fill in your actual API keys

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Anthropic API Key (Required for Claude models)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# OPTIONAL API KEYS (for additional search tools)
# =============================================================================

# OpenAI API Key (Optional - if you want to use OpenAI models)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Search API (Optional - for Google search tool)
# Get API key from: https://developers.google.com/custom-search/v1/introduction
# Create Custom Search Engine at: https://cse.google.com/cse/
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_custom_search_engine_id_here

# Bing Search API (Optional - for Bing search tool)
# Get API key from: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
BING_SUBSCRIPTION_KEY=your_bing_subscription_key_here

# =============================================================================
# APPLICATION SETTINGS (Optional)
# =============================================================================

# Model Configuration
# Anthropic model to use (default: claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# OpenAI model to use (default: gpt-4)
OPENAI_MODEL=gpt-4

# Temperature setting for models (0.0 to 1.0, default: 0)
MODEL_TEMPERATURE=0

# Verbose logging for debugging (true/false, default: false)
VERBOSE_LOGGING=false

# =============================================================================
# INSTRUCTIONS
# =============================================================================
# 
# 1. Copy this file and rename it to .env
# 2. Replace the placeholder values with your actual API keys
# 3. At minimum, you need ANTHROPIC_API_KEY to run the application
# 4. DuckDuckGo and Wikipedia search work without API keys
# 5. Google and Bing search require their respective API keys
# 6. Never commit your .env file to version control!
#
# =============================================================================
